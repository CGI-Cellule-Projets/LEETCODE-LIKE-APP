# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=coding_platform

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=24h

# Server Configuration
PORT=3001
NODE_ENV=development

# Demo Mode Flags
# Enable temporary frontend fallbacks (mock contests/local login fallback) only for local demos.
DEV_DEMO_MODE=false
# Allow local-machine admin bypass without token (development only).
ALLOW_LOCAL_ADMIN_BYPASS=false
